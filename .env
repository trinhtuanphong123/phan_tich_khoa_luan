# Centralized configuration for VNStock AI Hedge Fund
# Trading defaults
PORTFOLIO_CASH=1000000000
LOT_SIZE=100
SETTLEMENT_LAG_DAYS=2
BUY_FEE_RATE=0.0015
SELL_FEE_RATE=0.0025
MAX_TRADE_PCT=25.0
MAX_BUYS_PER_TICKER=100

# Strategy thresholds
PRICE_CHANGE_THRESHOLD=2.0
VOL_RATIO_THRESHOLD=1.5
NEWS_MIN_COUNT=1
NEWS_LOOKBACK_DAYS=3
ALPHA_THRESHOLD=60.0
SELL_THRESHOLD_OFFSET=5.0
ATR_SCALE=1.5
WEIGHT_ALPHA=0.6
WEIGHT_BETA=0.4
WEIGHT_INCREMENT_BUFFER_PCT=0.5

# Workflow weights
TRAD_TARGET_WEIGHT=10.0
KELLY_MIN_WEIGHT_PCT=5.0
KELLY_MAX_WEIGHT_PCT=40.0

# Risk Limits (all values in percentage)
MAX_POSITION_PCT=25.0
MAX_PORTFOLIO_INVESTED_PCT=85.0
STOP_LOSS_PCT=7.0
MAX_DRAWDOWN_PCT=25.0
MAX_SECTOR_EXPOSURE_PCT=40.0
MIN_CASH_RESERVE_PCT=25.0

# Models and LLM
# Tier 2 Agents
T2_MACRO=gpt-5.2
T2_NEWS=gpt-5.2
T2_FINANCIAL=gpt-5.2
T2_TECHNICAL=gpt-5.2
T2_QUANT=gpt-5.2

# Tier 3 Agents
T3_DEBATE=gpt-5.2
T3_ARGUMENT=gpt-5.2

# Tier 4 Agent
T4_CIO=gpt-5.2

# Daily Reporter
DAILY_REPORT=gpt-5.2

PRIMARY_MODEL=gpt-5.2
FINANCIAL_MODEL=gpt-5.2
NEWS_MODEL=gpt-5.2
GPT_MODEL=gpt-5.2
LLM_CONCURRENCY=20
CLIPROXY_BASE_URL=http://127.0.0.1:8317/v1
CLIPROXY_API_KEY=sk-my-key-is-empty

# Paths
DATA_DIR=data
VNSTOCK_DB_PATH=data/vnstock.db
NEWS_DB_PATH=data/news.db
COGNITIVE_DB_PATH=data/cognitive.db
MARKET_DB_PATH=data/market.db
BACKTEST_RESULTS_DIR=backtest_results

# RAG
ROUTE_MODEL=gpt-5.2
LLM_MODEL_NAME=gpt-5.2
JUDGE_MODEL_NAME=gpt-5.2
REASONER_MODEL=gpt-5.2

EMBEDDING_MODEL_NAME=BAAI/bge-m3

WORKDIR=./vnstock/rag_storage
MAX_REQUESTS_PER_MINUTE=25 
CHUNK_SIZE=4096 
CHUNK_OVERLAP=350

EMBEDDING_TIMEOUT=600

HF_HUB_VERBOSITY=error
TRANSFORMERS_VERBOSITY=error

